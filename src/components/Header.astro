---
import { Icon } from "astro-icon/components";
// Header.astro
// Componente de navegación principal
---

<header
  class="w-full bg-navy-950 backdrop-blur-md sticky top-0 z-50 border-b border-navy-800"
>
  <div class="max-w-7xl mx-auto px-6 py-2 flex items-center justify-between relative z-50">
    <!-- Logo -->
    <a href="/" class="transition-base hover:opacity-80 block relative z-50">
      <img
        src="/images/branding/icon_copper.png"
        alt="Pacto"
        class="h-10 md:h-12 w-auto"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex gap-8">
      <a
        href="/#nosotros"
        class="text-shadow-md tracking-wide text-warm-50 hover:text-copper-500 transition-base"
        >Nosotros</a
      >
      <a
        href="/#servicios"
        class="text-md tracking-wide text-warm-50 hover:text-copper-500 transition-base"
        >Servicios</a
      >
      <a
        href="/#proyectos"
        class="text-md tracking-wide text-warm-50 hover:text-copper-500 transition-base"
        >Proyectos</a
      >
      <a
        href="/#contacto"
        class="text-md tracking-wide text-warm-50 hover:text-copper-500 transition-base"
        >Contacto</a
      >
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-warm-50 cursor-pointer hover:text-copper-500 transition-colors relative z-50 p-2"
      aria-label="Abrir menú"
    >
      <Icon name="lucide:menu" class="w-6 h-6" id="menu-icon-open" />
      <Icon name="lucide:x" class="w-6 h-6 hidden" id="menu-icon-close" />
    </button>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div
    id="mobile-menu"
    class="absolute top-full left-0 w-full bg-navy-950/98 backdrop-blur-xl border-b border-navy-800 shadow-2xl transition-all duration-300 transform origin-top hidden flex-col z-40"
  >
    <nav class="flex flex-col items-center py-12 gap-8">
      <a
        href="/#nosotros"
        class="mobile-link text-3xl font-display text-warm-50 hover:text-copper-500 transition-colors"
        >Nosotros</a
      >
      <a
        href="/#servicios"
        class="mobile-link text-3xl font-display text-warm-50 hover:text-copper-500 transition-colors"
        >Servicios</a
      >
      <a
        href="/#proyectos"
        class="mobile-link text-3xl font-display text-warm-50 hover:text-copper-500 transition-colors"
        >Proyectos</a
      >
      <a
        href="/#contacto"
        class="mobile-link text-3xl font-display text-warm-50 hover:text-copper-500 transition-colors"
        >Contacto</a
      >
    </nav>
  </div>
</header>

<script>
  // Script para manejar la apertura y cierre del menú móvil de forma dinámica
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");
  const links = document.querySelectorAll(".mobile-link");

  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener("click", () => {
      const isHidden = menu.classList.contains("hidden");
      
      if (isHidden) {
        menu.classList.remove("hidden");
        menu.classList.add("flex");
        iconOpen.classList.add("hidden");
        iconClose.classList.remove("hidden");
      } else {
        menu.classList.add("hidden");
        menu.classList.remove("flex");
        iconOpen.classList.remove("hidden");
        iconClose.classList.add("hidden");
      }
    });

    // Cerrar automáticamente al seleccionar una sección
    links.forEach(link => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        menu.classList.remove("flex");
        iconOpen.classList.remove("hidden");
        iconClose.classList.add("hidden");
      });
    });
  }
</script>
