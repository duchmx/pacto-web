---
import { Image } from "astro:assets";

interface Props {
  href: string;
  image: string | any;
  category: string;
  title: string;
  isLast?: boolean;
}

const { href, image, category, title, isLast = false } = Astro.props;
---

<a
  href={href}
  class={`relative group flex-1 hover:flex-[3] transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] overflow-hidden cursor-pointer ${
    !isLast ? "border-b md:border-b-0 md:border-r border-warm-200" : ""
  }`}
>
  {
    typeof image === "string" ? (
      <img
        src={image}
        alt={title}
        class="absolute inset-0 w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105"
      />
    ) : (
      <Image
        src={image}
        alt={title}
        class="absolute inset-0 w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105"
      />
    )
  }
  <div
    class="absolute inset-0 bg-navy-950/40 group-hover:bg-transparent transition-colors duration-700"
  >
  </div>
  <div
    class="absolute inset-x-0 bottom-0 h-2/3 bg-linear-to-t from-navy-950/90 via-navy-950/30 to-transparent opacity-90 transition-opacity duration-700"
  >
    <div class="absolute bottom-8 left-8 right-8 flex flex-col justify-end">
      <span
        class="label-mono text-copper-400 opacity-0 group-hover:opacity-100 transition-all duration-700 translate-y-4 group-hover:translate-y-0 delay-100"
        >{category}</span
      >
      <h3
        class="text-2xl md:text-4xl font-display text-warm-50 mt-1 mb-2 whitespace-nowrap overflow-hidden text-ellipsis"
      >
        {title}
      </h3>
      <div
        class="copper-rule w-0 group-hover:w-16 transition-all duration-700 delay-200"
      >
      </div>
    </div>
  </div>
</a>
