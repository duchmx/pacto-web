---
/**
 * BaseLayout.astro
 * Layout base del sitio. Todos los demás layouts y páginas lo extienden.
 *
 * Props:
 *   title       — Título de la página (aparece en la pestaña y en Google)
 *   description — Meta description para SEO (140–160 caracteres ideal)
 *   image       — URL absoluta de la imagen OG (para WhatsApp, redes, etc.)
 *   noindex     — Si true, le dice a Google que no indexe esta página
 */

import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFAB from "../components/ui/WhatsAppFAB.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Construimos relaciones sólidas para desarrollar proyectos inmobiliarios de gran rentabilidad.",
  image = "/og-default.png",
  noindex = false,
} = Astro.props;

// URL canónica — evita duplicados en Google
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Título completo con nombre del cliente al final
const fullTitle =
  title === "Inicio" ? "Pacto Inmobiliario" : `${title} · Pacto Inmobiliario`;
---

<!DOCTYPE html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ========================
       SEO BÁSICO
  ========================= -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- ========================
       OPEN GRAPH (redes sociales, WhatsApp, iMessage)
  ========================= -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={new URL(image, Astro.site || "http://localhost")}
    />
    <meta property="og:locale" content="es_MX" />

    <!-- ========================
       TWITTER / X CARD
  ========================= -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={new URL(image, Astro.site || "http://localhost")}
    />

    <!-- ========================
       SCHEMA.ORG — LocalBusiness + RealEstateAgent
       Le da señales fuertes a Google para búsquedas locales.
       Edita los valores entre comillas con los datos reales del cliente.
  ========================= -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": ["RealEstateAgent", "LocalBusiness"],
        name: "Pacto Inmobiliario",
        description: "Proyectos inmobiliarios de gran rentabilidad.",
        url: "https://www.pacto.mx",
        logo: "https://www.pacto.mx/favicon.svg",
        image: "https://www.pacto.mx/og-default.png",
        telephone: "+52-999-948-2748",
        email: "hola@pacto.mx",
        address: {
          "@type": "PostalAddress",
          streetAddress:
            "Torre Banorte - 3er Piso, Prol. Paseo Montejo 310, Interior 14",
          addressLocality: "Mérida",
          addressRegion: "Yucatán",
          postalCode: "97118",
          addressCountry: "MX",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: 21.023715,
          longitude: -89.622642,
        },
        sameAs: [
          "https://www.instagram.com/pacto_inmobiliario",
          // Agrega aquí enlaces a redes cuando las tengas
        ],
      })}
    ></script>

    <!-- ========================
       TIPOGRAFÍAS — Google Fonts
       display=swap evita que el texto sea invisible mientras cargan.
  ========================= -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=DM+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    <!-- ========================
       CSS GLOBAL
       (Importado vía Vite en el frontmatter)
  ========================= -->

    <!-- ========================
       FAVICON & PWA
       Genera los tuyos en https://realfavicongenerator.net
  ========================= -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Pacto" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Slot para meta tags adicionales por página (ej: meta de proyecto específico) -->
    <slot name="head" />
  </head>

  <body>
    <!-- ========================
       NAVEGACIÓN
  ========================= -->
    <Header />

    <!-- ========================
       CONTENIDO PRINCIPAL
  ========================= -->
    <main class="min-h-screen">
      <slot />
    </main>

    <!-- ========================
       FOOTER
  ========================= -->
    <WhatsAppFAB />
    <Footer />
  </body>
</html>
