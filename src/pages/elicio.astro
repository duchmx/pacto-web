---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

export const prerender = true;
---

<BaseLayout
  title="Elicio Duch - Contacto"
  description="Tarjeta de contacto de Elicio Duch, Pacto Inmobiliario."
>
  <section
    class="min-h-screen bg-navy-950 flex justify-center items-center px-4 py-12 relative overflow-hidden"
  >
    <!-- Light Gradient Overlay -->
    <div
      class="absolute inset-0 z-0 opacity-40 mix-blend-overlay bg-linear-to-t from-copper-900/60 via-navy-900 to-navy-950"
    >
    </div>

    <!-- Main Card Container -->
    <div
      class="z-10 bg-warm-50 p-8 md:p-12 w-full max-w-sm shadow-2xl flex flex-col items-center"
    >
      <!-- Profile Header -->
      <div class="mb-6 flex flex-col items-center">
        <div
          class="w-28 h-28 rounded-full bg-navy-950 flex items-center justify-center mb-6 shadow-xl border-4 border-warm-50 relative"
        >
          <span class="text-4xl font-display text-copper-500 italic">ED</span>
        </div>
        <h1
          class="text-3xl font-display text-navy-900 text-center leading-tight mb-2"
        >
          Elicio Duch
        </h1>
        <p
          class="text-copper-600 font-medium tracking-[0.2em] text-[10px] md:text-xs uppercase text-center"
        >
          Pacto Inmobiliario
        </p>
      </div>

      <!-- Contact Info List -->
      <div class="w-full space-y-4 mb-10 mt-4">
        <a
          href="tel:+529931779143"
          class="flex items-center gap-4 text-navy-800 hover:text-copper-600 transition-colors group"
        >
          <div
            class="shrink-0 w-12 h-12 rounded-full border border-navy-900/10 bg-warm-100 flex items-center justify-center group-hover:border-copper-500/30 group-hover:bg-copper-50 transition-all duration-300"
          >
            <Icon
              name="lucide:phone"
              class="w-5 h-5 opacity-70 group-hover:opacity-100"
            />
          </div>
          <span class="font-light tracking-wide">+52 993 177 9143</span>
        </a>

        <a
          href="mailto:elicio@pacto.mx"
          class="flex items-center gap-4 text-navy-800 hover:text-copper-600 transition-colors group"
        >
          <div
            class="shrink-0 w-12 h-12 rounded-full border border-navy-900/10 bg-warm-100 flex items-center justify-center group-hover:border-copper-500/30 group-hover:bg-copper-50 transition-all duration-300"
          >
            <Icon
              name="lucide:mail"
              class="w-5 h-5 opacity-70 group-hover:opacity-100"
            />
          </div>
          <span class="font-light tracking-wide text-sm md:text-base"
            >elicio@pacto.mx</span
          >
        </a>

        <a
          href="https://pacto.mx"
          class="flex items-center gap-4 text-navy-800 hover:text-copper-600 transition-colors group"
        >
          <div
            class="shrink-0 w-12 h-12 rounded-full border border-navy-900/10 bg-warm-100 flex items-center justify-center group-hover:border-copper-500/30 group-hover:bg-copper-50 transition-all duration-300"
          >
            <Icon
              name="lucide:globe"
              class="w-5 h-5 opacity-70 group-hover:opacity-100"
            />
          </div>
          <span class="font-light tracking-wide">pacto.mx</span>
        </a>
      </div>

      <!-- Save Button -->
      <a
        href="/api/elicio.vcf"
        download="elicio.vcf"
        class="w-full relative px-6 py-5 outline-none overflow-hidden bg-navy-950 text-warm-50 text-xs tracking-[0.2em] uppercase font-medium hover:bg-navy-900 transition-colors text-center group shadow-xl"
      >
        <span class="relative z-10 flex items-center justify-center gap-3">
          <Icon name="lucide:download" class="w-4 h-4" />
          Guardar Contacto
        </span>
        <div
          class="absolute inset-0 bg-copper-600/20 scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100 z-0"
        >
        </div>
      </a>
    </div>
  </section>
</BaseLayout>
